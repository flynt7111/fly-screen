{
  "name": "fly-screen",
  "version": "1.0.0",
  "description": "Fly Screen - Fullscreen video display app with floating menu",
  "author": "Flynt",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && xcopy /Y /I src\\renderer\\index.html dist\\renderer\\ && xcopy /Y /I src\\renderer\\styles.css dist\\renderer\\",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "package": "npm run build && electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0"
  },
  "build": {
    "appId": "com.flyscreen.app",
    "productName": "Fly Screen",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "ffmpeg.exe"
      }
    ],
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "FlyScreen.exe"
    }
  }
}
